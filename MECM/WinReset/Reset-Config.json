{
    "_comment": "Configuration for zero-touch remote factory reset. Edit for your environment.",

    "Domain": {
        "FQDN": "contoso.com",
        "NetBIOS": "CONTOSO",
        "DefaultOU": "OU=Workstations,DC=contoso,DC=com"
    },

    "InstallSequence": [
        {
            "Name": "VC++ Redistributable (x64)",
            "InstallerFile": "vc_redist.x64.exe",
            "SilentArgs": "/install /quiet /norestart",
            "ValidationPath": null,
            "RebootAfter": false,
            "Priority": 1
        },
        {
            "Name": "VC++ Redistributable (x86)",
            "InstallerFile": "vc_redist.x86.exe",
            "SilentArgs": "/install /quiet /norestart",
            "ValidationPath": null,
            "RebootAfter": true,
            "Priority": 2
        },
        {
            "Name": ".NET Desktop Runtime 8",
            "InstallerFile": "windowsdesktop-runtime-8.0.x-win-x64.exe",
            "SilentArgs": "/install /quiet /norestart",
            "ValidationPath": null,
            "RebootAfter": false,
            "Priority": 3
        },
        {
            "Name": "Cisco Secure Connect Root CA",
            "InstallerFile": "CiscoSecureConnect-RootCA.cer",
            "SilentArgs": "Root",
            "ValidationPath": null,
            "RebootAfter": false,
            "Priority": 5,
            "_comment": "SilentArgs = certificate store name (Root, CA, My, TrustedPublisher)"
        },
        {
            "Name": "ZPA Intermediate CA",
            "InstallerFile": "ZscalerRootCA.cer",
            "SilentArgs": "Root",
            "ValidationPath": null,
            "RebootAfter": false,
            "Priority": 6
        },
        {
            "Name": "SentinelOne Root CA",
            "InstallerFile": "S1-RootCA.cer",
            "SilentArgs": "Root",
            "ValidationPath": null,
            "RebootAfter": false,
            "Priority": 7
        },
        {
            "Name": "Zscaler Connector",
            "InstallerFile": "ZscalerConnector.exe",
            "SilentArgs": "/S",
            "ValidationPath": "C:\\Program Files\\Zscaler\\ZSATunnel.exe",
            "RebootAfter": false,
            "Priority": 10
        },
        {
            "Name": "CrowdStrike Falcon Sensor",
            "InstallerFile": "WindowsSensor.exe",
            "SilentArgs": "/install /quiet /norestart CID=YOUR_CID_HERE",
            "ValidationPath": "C:\\Program Files\\CrowdStrike\\CSFalconService.exe",
            "RebootAfter": false,
            "Priority": 11
        },
        {
            "Name": "TeamViewer Host",
            "InstallerFile": "TeamViewer_Host.msi",
            "SilentArgs": "/qn /norestart",
            "ValidationPath": "C:\\Program Files\\TeamViewer\\TeamViewer.exe",
            "RebootAfter": false,
            "Priority": 20
        }
    ],

    "MECMClient": {
        "InstallerPath": "\\\\cm01\\SMS_MCM\\Client\\ccmsetup.exe",
        "SilentArgs": "/mp:cm01.contoso.com SMSSITECODE=MCM /NoCRLCheck",
        "InstallLast": true
    },

    "WiFi": {
        "ExportProfiles": true
    },

    "Locale": "en-US",
    "Keyboard": "0409:00000409",

    "Recovery": {
        "CustomizationsPath": "C:\\Recovery\\Customizations",
        "AutoApplyPath": "C:\\Recovery\\AutoApply"
    }
}
